# VLLM Studio Environment Variables
# Copy to .env and customize

PORT=3333
HOST=127.0.0.1
VLLM_PORT=8000
DATA_DIR=./data
LOG_LEVEL=info

# Path to the Python executable inside the vLLM virtual environment.
# Set automatically by run.sh. If running backend directly, point this
# to the venv Python (e.g. ./venv/bin/python3).
VLLM_PYTHON=./venv/bin/python3
